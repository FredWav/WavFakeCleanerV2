# ── Wav Fake Cleaner V2 ─────────────────────────────
#
# Tu peux aussi changer ces parametres depuis le
# dashboard web (bouton "Parametres").
#

# Ton nom d'utilisateur Threads (sans le @)
WAV_THREADS_USERNAME=your_username_here

# Mode headless : true = pas de fenetre navigateur visible
WAV_HEADLESS=true

# Nombre max de navigateurs en parallele (1-5)
WAV_MAX_BROWSER_CONTEXTS=3

# Seuil de detection fake (0-100, defaut: 70)
WAV_SCORE_THRESHOLD=70

# Nombre d'actions avant une grosse pause
WAV_ACTIONS_BEFORE_MACRO=25

# Port du serveur web
WAV_API_PORT=8000
