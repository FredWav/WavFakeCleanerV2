# ── Wav Fake Cleaner V2 ─────────────────────────────
#
# Copier ce fichier en .env et remplir les valeurs.
# Toutes les variables sont prefixees WAV_ (pydantic-settings).
#

# ── Threads ─────────────────────────────────────────
# Ton nom d'utilisateur Threads (sans le @)
WAV_THREADS_USERNAME=your_username_here

# Mode headless : true = pas de fenetre navigateur visible
WAV_HEADLESS=true

# Nombre max de navigateurs en parallele (1-5)
WAV_MAX_BROWSER_CONTEXTS=3

# Seuil de detection fake (0-100, defaut: 70)
WAV_SCORE_THRESHOLD=70

# Nombre d'actions avant une grosse pause
WAV_ACTIONS_BEFORE_MACRO=25

# Port du serveur web
WAV_API_PORT=8000

# ── JWT Authentication ──────────────────────────────
# IMPORTANT: Generer un secret pour la production !
# python -c "import secrets; print(secrets.token_hex(32))"
WAV_JWT_SECRET=CHANGE-ME-in-production-use-openssl-rand-hex-32
WAV_JWT_ALGORITHM=HS256
WAV_JWT_EXPIRE_MINUTES=10080

# ── Stripe Billing ──────────────────────────────────
# https://dashboard.stripe.com
WAV_STRIPE_SECRET_KEY=sk_test_...
WAV_STRIPE_WEBHOOK_SECRET=whsec_...
WAV_STRIPE_PRICE_ID=price_...

# ── Email (Resend ou Mailgun) ───────────────────────
WAV_EMAIL_PROVIDER=resend
WAV_EMAIL_API_KEY=re_...
WAV_EMAIL_FROM=WavFakeCleaner <noreply@wavfakecleaner.com>
WAV_EMAIL_BASE_URL=https://wavfakecleaner.com

# ── Quotas ──────────────────────────────────────────
WAV_FREE_REMOVALS_PER_DAY=50
WAV_PRO_REMOVALS_PER_DAY=999999

# ── Rate Limits ─────────────────────────────────────
WAV_MAX_ACTIONS_PER_HOUR=120
WAV_MAX_ACTIONS_PER_DAY=800

# ── Pacer Delays (secondes) ────────────────────────
WAV_MICRO_DELAY_MIN=1.5
WAV_MICRO_DELAY_MAX=4.0
WAV_MACRO_DELAY_MIN=30.0
WAV_MACRO_DELAY_MAX=90.0
